# Telegram approval bot. Keep real values in .env.local.
STEVE_TRADE_BOT_TOKEN=
STEVE_TRADE_APPROVAL_CHAT_ID=
STEVE_TRADE_APPROVAL_CHAT_IDS=
STEVE_TRADE_OWNER_CHAT_ID=
STEVE_TRADE_OWNER_USER_ID=

# Alpaca paper/data credentials. Keep paper endpoint for all broker execution.
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_API_DATA_BASE_URL=https://data.alpaca.markets
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
OPENCLAW_TRADING_MODE=paper
OPENCLAW_ENABLE_PAPER_ORDERS=false
OPENCLAW_MAX_ENTRY_SLIPPAGE_PCT=5
OPENCLAW_QUOTE_SNAPSHOT_MIN_MOVE_PCT=5
OPENCLAW_QUOTE_SNAPSHOT_FORCE_INTERVAL_SECONDS=1800

# Optional Alpaca data feeds.
ALPACA_STOCK_FEED=iex
ALPACA_OPTIONS_FEED=indicative
